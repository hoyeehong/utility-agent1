# ============================================================
# ENVIRONMENT VARIABLES - UTILITY BILL CALCULATOR (Python/FastAPI)
# Copy this file to .env and configure for your setup
# ============================================================

# === Application Configuration ===
ENV=development
HOST=0.0.0.0
PORT=8000

# === MESSAGING SERVICE ===
# Telegram bot (FREE, RECOMMENDED)
TELEGRAM_BOT_TOKEN=your-bot-token-here-123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional: Production webhook URL
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/telegram

# ============================================================
# SUPABASE (FREE TIER)
# Get from: https://app.supabase.com/project
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ============================================================
# GOOGLE CLOUD VISION (FREE - 1000 calls/month)
# Set to path of JSON credentials file from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# ============================================================
# ENCRYPTION (AES-256)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex characters (32 bytes)
# ============================================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================
# CALCULATOR API
# Your existing calculator endpoint
# ============================================================
CALCULATOR_API_URL=http://localhost:3000/api/calculate-bill

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO

