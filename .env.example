# ============================================================
# ENVIRONMENT VARIABLES - UTILITY BILL CALCULATOR (Python/FastAPI)
# Copy this file to .env and configure for your setup
# ============================================================

# === Application Configuration ===
ENV=development
HOST=0.0.0.0
PORT=8000

# ============================================================
# REQUIRED: TELEGRAM BOT (FREE)
# Create bot: https://t.me/BotFather
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token-here-123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ============================================================
# REQUIRED: SUPABASE (FREE TIER)
# Setup project: https://app.supabase.com
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ============================================================
# OPTIONAL: GOOGLE CLOUD VISION (FREE - 1000 calls/month)
# Set to path of JSON credentials file from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Leave blank to skip OCR, bill calculator will still work
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# ============================================================
# OPTIONAL: ENCRYPTION (AES-256)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex characters (32 bytes)
# ============================================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================
# OPTIONAL: LOGGING
# ============================================================
LOG_LEVEL=INFO

