# ============================================================
# ENVIRONMENT VARIABLES - UTILITY BILL CALCULATOR
# Vercel Serverless + Supabase + Telegram Bot
# Copy to Vercel Dashboard → Settings → Environment Variables
# ============================================================

# === Application Configuration ===
ENV=production
HOST=0.0.0.0
PORT=8000

# ============================================================
# REQUIRED: TELEGRAM BOT (FREE)
# Get from: @BotFather on Telegram
# Format: 123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ============================================================
# REQUIRED: SUPABASE (FREE TIER - 500MB DB)
# Get from: https://app.supabase.com/project/settings/api
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ============================================================
# OPTIONAL: GOOGLE CLOUD VISION (FREE - 1000 calls/month)
# For image OCR. Leave blank if using text input only.
# Get from: https://console.cloud.google.com/apis/credentials
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# ============================================================
# OPTIONAL: ENCRYPTION (AES-256)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex characters (32 bytes)
# ============================================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================
# OPTIONAL: TELEGRAM ADMIN ID
# Your Telegram user ID (for admin commands)
# Get from: Send /start to @userinfobot
# ============================================================
TELEGRAM_ADMIN_ID=123456789

# ============================================================
# OPTIONAL: LOGGING
# ============================================================
LOG_LEVEL=INFO

